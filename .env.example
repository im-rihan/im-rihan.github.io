# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# Supabase → Project Settings → API
# GitHub Pages → Settings → Secrets → Actions (same keys, then redeploy)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional — privacy-friendly page analytics (https://plausible.io)
# Set to your domain (e.g. im-rihan.github.io) to load the Plausible script.
# Leave empty to disable. No cookies; GDPR-friendly alternative to Google Analytics.
# Add the same var to GitHub Actions secrets if you want it in production builds.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Optional — CountAPI global visit counters (https://countapi.xyz).
# Set to false to disable; UI shows "unavailable" instead of a silent zero.
NEXT_PUBLIC_COUNTAPI_ENABLED=true

# Optional — force demo analytics on /status (true) or live data on localhost (false).
# When unset, demo mode is localhost-only unless ?demo=1 or ?live=1 is in the URL.
NEXT_PUBLIC_DEMO_ANALYTICS=
